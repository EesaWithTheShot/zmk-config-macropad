config SSD1322_PATCHED
    bool "Use patched SSD1322 driver (with grayscale + inversion)"
    default y
    depends on DISPLAY && MIPI_DBI

config SSD1322_DEFAULT_GRAYSCALE
    bool "Default SSD1322 to L_8 grayscale pixel format"
    depends on SSD1322_PATCHED

config SSD1322_CONV_BUFFER_LINES
    int "Lines of conversion buffer per SSD1322 instance"
    default 4
    depends on SSD1322_PATCHED